# Database
DATABASE_URL=file:./data/dev.db

# --- Local development (recommended) ---
# Unlocks Pro limits without Lemon Squeezy or a paid subscription. See TODO.md before production.
BYPASS_PAYMENT_GATING=true
# Optional: skip OAuth and use a fixed dev user (never enable in production).
# NEXTAUTH_DEV_BYPASS=true

# Groq — dev-only fallback when NEXTAUTH_DEV_BYPASS or NODE_ENV=development (BYOK in production)
GROQ_API_KEY=gsk_...

# Encrypts user-supplied AI keys at rest (required in production)
AI_KEY_ENCRYPTION_SECRET=

# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=

# --- Lemon Squeezy (configure later; see TODO.md) ---
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Resend (optional; email when a portfolio is first published)
RESEND_API_KEY=re_...
# RESEND_FROM="FolioMint <onboarding@resend.dev>"

# Turso (production only)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
