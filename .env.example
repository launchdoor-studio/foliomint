# Database
DATABASE_URL=file:./data/dev.db

# --- Local development (recommended) ---
# One switch for frictionless local testing: skips OAuth, unlocks Pro features, and stubs AI
# when GROQ_API_KEY is missing. Never enable in production.
LOCAL_DEV_MODE=true
# Or set individually instead of LOCAL_DEV_MODE:
# NEXTAUTH_DEV_BYPASS=true
# BYPASS_PAYMENT_GATING=true

# Groq — platform AI key for parsing, Mint, and resume improvements (optional in LOCAL_DEV_MODE)
GROQ_API_KEY=

# Launch promo: 14-day Pro trial for signups before this date (ISO 8601)
# SIGNUP_TRIAL_PROMO_END=2026-09-04T23:59:59.999Z
# SIGNUP_TRIAL_DAYS=14

# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=

# Launch offer: $25/year Pro variant (annual subscription in Lemon Squeezy)
# LAUNCH_OFFER_END=2026-08-04T23:59:59.999Z
LEMONSQUEEZY_LAUNCH_VARIANT_ID=

# --- Lemon Squeezy (configure later; see TODO.md) ---
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Resend (optional; email when a portfolio is first published)
RESEND_API_KEY=re_...
# RESEND_FROM="FolioMint <onboarding@resend.dev>"

# Turso (production only)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
